{
  "name": "mini-dex-monorepo",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "solidity",
    "hardhat",
    "react",
    "typescript",
    "ethers",
    "defi",
    "dex",
    "amm",
    "constant-product",
    "web3"
  ],
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "node-run": "npx hardhat node",
    "deploy": "npx hardhat run scripts/deploy.js --network localhost",
    "deploy-securechain": "npx hardhat run scripts/deploy.js --network securechain",
    "frontend-install": "npm install --prefix frontend",
    "frontend-dev": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run node-run\" \"sleep 2 && npm run deploy\" \"npm run frontend-dev\""
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "concurrently": "^8.2.2",
    "dotenv": "^17.4.2",
    "hardhat": "^2.22.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}
